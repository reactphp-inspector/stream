{
    "name": "react-inspector/stream",
    "description": "\ud83c\udf0a React Stream throughput inspector",
    "license": "MIT",
    "authors": [
        {
            "name": "Cees-Jan Kiewiet",
            "email": "ceesjank@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "nikic/php-parser": "^4.3",
        "react-inspector/global-state": "dev-switch-to-wyrihaximus-metrics-for-metrics",
        "react/event-loop": "^1.0",
        "react/stream": "^1.0",
        "reactivex/rxphp": "^2.0",
        "roave/better-reflection": "^5",
        "wyrihaximus/constants": "^1.5",
        "wyrihaximus/iterator-or-array-to-array": "^1.1",
        "wyrihaximus/metrics": "^1.1",
        "wyrihaximus/metrics-lazy-registry": "^1.0"
    },
    "require-dev": {
        "wyrihaximus/async-test-utilities": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "ReactInspector\\Stream\\": "src/"
        },
        "files": [
            "src/bootstrap.php",
            "src/include.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "ReactInspector\\Tests\\Stream\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ocramius/package-versions": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "infection/extension-installer": true,
            "ergebnis/composer-normalize": true,
            "icanhazstring/composer-unused": true
        },
        "platform": {
            "php": "8.0.99"
        },
        "sort-packages": true
    },
    "scripts": {
        "post-install-cmd": [
            "composer normalize"
        ],
        "post-update-cmd": [
            "composer normalize"
        ]
    }
}
